# ==========================
# Pundit Protocol Backend
# Copy this file to .env and fill in values.
# ==========================

# Required for NewsAPI article fetches (used by debate briefing pipeline)
NEWSAPI_KEY=your_newsapi_key_here
# Optional alias supported by code (use one or the other)
# NEWS_API_KEY=your_newsapi_key_here

# LLM provider selector: gemini (default) or openai
LLM_PROVIDER=gemini

# Required for Gemini-backed pundit turns and moderator overview/summary (default path)
GOOGLE_API_KEY=your_google_ai_api_key_here

# Optional: needed only when LLM_PROVIDER=openai or as runtime fallback if Gemini fails
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------
# Optional runtime settings
# --------------------------

# News API endpoint override
NEWS_API_URL=https://newsapi.org/v2/everything

# LLM model names
PUNDIT_GEMINI_MODEL=models/gemini-2.5-flash-lite
MODERATOR_GEMINI_MODEL=models/gemini-2.5-flash-lite
PUNDIT_OPENAI_MODEL=gpt-4o-mini
MODERATOR_OPENAI_MODEL=gpt-4o-mini

# Debate controls
DEBATE_ROUNDS=2
DEBATE_QUEUE_TIMEOUT=120
